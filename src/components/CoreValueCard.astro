---
interface Props {
  icon: string; // SVG string
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="core-value-card">
  <div class="icon-wrap" aria-hidden="true">
    <Fragment set:html={icon} />
  </div>
  <h3 class="value-title">{title}</h3>
  <p class="value-desc">{description}</p>
</div>

<style>
  .core-value-card {
    background: var(--color-surface);
    border: 1px solid rgba(215, 38, 61, 0.4);
    border-radius: var(--radius-card);
    padding: var(--space-lg) var(--space-md);
    text-align: center;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .core-value-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background: var(--color-gradient);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .core-value-card:hover {
    border-color: #e8566a;
    box-shadow: var(--glow-sm), var(--shadow-card);
    transform: translateY(-5px);
  }

  .core-value-card:hover::before {
    opacity: 1;
  }

  .icon-wrap {
    width: 60px;
    height: 60px;
    background: var(--color-gradient-soft);
    border: 1px solid rgba(215, 38, 61, 0.2);
    border-radius: var(--radius-card);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md);
    color: var(--color-primary-light);
    transition: box-shadow var(--transition-base);
  }

  .core-value-card:hover .icon-wrap {
    box-shadow: var(--glow-sm);
  }

  .value-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.6rem;
  }

  .value-desc {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }
</style>
