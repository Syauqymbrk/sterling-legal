---
const navLinks = [
  { href: "/", label: "Beranda" },
  { href: "/about", label: "Tentang" },
  { href: "/practice-areas", label: "Bidang Hukum" },
  { href: "/team", label: "Tim" },
  { href: "/contact", label: "Kontak" },
];
---

<footer class="site-footer">
  <div class="container">
    <!-- Top grid -->
    <div class="footer-grid">
      <!-- Col 1: Brand -->
      <div class="footer-brand">
        <a
          href="/"
          class="footer-logo"
          aria-label="Sterling Legal"
          style="display: flex; align-items: center; gap: 10px;"
        >
          <img
            src="/logo.svg"
            alt="Sterling Legal"
            width="48"
            height="48"
            style="background: white; border-radius: 50%; padding: 6px; border: 2px solid #C3132E; flex-shrink: 0;"
          />
          <span class="gradient-text">Sterling</span> Legal
        </a>
        <p class="footer-tagline" style="margin-top: 12px;">
          Keadilan yang Berkualitas,<br />Solusi yang Terpercaya.
        </p>
        <div class="footer-social">
          <a href="#" aria-label="Instagram Sterling Legal" class="social-link">
            <svg
              width="18"
              height="18"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="#" aria-label="LinkedIn Sterling Legal" class="social-link">
            <svg
              width="18"
              height="18"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Quick Nav -->
      <div class="footer-nav">
        <h4 class="footer-heading">Navigasi</h4>
        <ul class="footer-links">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Col 3: Contact -->
      <div class="footer-contact">
        <h4 class="footer-heading">Kontak</h4>
        <ul class="contact-list">
          <li class="contact-item">
            <svg
              class="contact-icon"
              width="16"
              height="16"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0z"
              ></path>
            </svg>
            <span
              >Perum Pabuaran Asri Blok B10 No.09<br />Rt.13 Rw.08, Kec.
              Cibinong<br />Kab. Bogor, Jawa Barat</span
            >
          </li>
          <li class="contact-item">
            <svg
              class="contact-icon"
              width="16"
              height="16"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
              ></path>
            </svg>
            <a href="mailto:syauqymubarok21@gmail.com" class="footer-email"
              >syauqymubarok21@gmail.com</a
            >
          </li>
          <li class="contact-item">
            <svg
              class="contact-icon"
              width="16"
              height="16"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25z"
              ></path>
            </svg>
            <a
              href="https://wa.me/6289516671039"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-email">+62 895-1667-1039</a
            >
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <div class="footer-divider"></div>
      <div class="flex-between footer-bottom-inner">
        <p class="footer-copy">
          &copy; 2026 <strong>Sterling Legal</strong>. Seluruh hak cipta
          dilindungi.
        </p>
        <p class="footer-copy">Dibuat dengan dedikasi untuk keadilan.</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border-subtle);
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-lg);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  /* Brand */
  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    display: inline-block;
    margin-bottom: var(--space-sm);
    transition: opacity var(--transition-fast);
  }
  .footer-logo:hover {
    opacity: 0.8;
  }

  .footer-tagline {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .footer-social {
    display: flex;
    gap: var(--space-xs);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .social-link:hover {
    color: var(--color-primary-light);
    border-color: var(--color-border);
    background: rgba(215, 38, 61, 0.08);
  }

  /* Nav column */
  .footer-heading {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-md);
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-link {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .footer-link::before {
    content: "";
    display: inline-block;
    width: 0;
    height: 1px;
    background: var(--color-primary);
    transition: width var(--transition-base);
    vertical-align: middle;
  }

  .footer-link:hover {
    color: var(--color-text);
  }

  .footer-link:hover::before {
    width: 12px;
  }

  /* Contact column */
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .contact-icon {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .footer-email {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }
  .footer-email:hover {
    color: var(--color-primary-light);
  }

  /* Bottom */
  .footer-divider {
    height: 1px;
    background: var(--color-border-subtle);
    margin-bottom: var(--space-md);
  }

  .footer-bottom-inner {
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .footer-copy {
    font-size: 0.82rem;
    color: var(--color-text-subtle);
    line-height: 1.5;
  }

  .footer-copy strong {
    color: var(--color-text-muted);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
