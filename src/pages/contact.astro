---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";

const formspreeId = "xkolalaq";
---

<MainLayout
  title="Hubungi Kami — Sterling Legal"
  description="Hubungi Sterling Legal untuk konsultasi awal. Kantor kami berlokasi di Cibinong, Bogor."
>
  <!-- Page Hero -->
  <section
    class="page-hero section"
    id="contact-hero"
    aria-label="Hubungi Kami"
  >
    <div class="blob blob-hero" aria-hidden="true"></div>
    <div class="container">
      <div class="page-hero-inner text-center">
        <div
          class="section-label"
          style="margin-inline:auto;display:flex;width:fit-content;"
        >
          Kontak
        </div>
        <h1>Mari <span class="gradient-text">Berdiskusi</span></h1>
        <div class="divider divider--center"></div>
        <p class="page-hero-sub">
          Jangan ragu untuk menghubungi kami. Tim Sterling Legal siap
          mendengarkan masalah Anda dan memberikan arahan hukum yang tepat.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Split Layout -->
  <section
    class="section section--sm"
    id="contact-content"
    aria-label="Formulir dan Informasi Kontak"
  >
    <div class="container">
      <div class="contact-grid">
        <!-- Left: Form -->
        <div class="contact-form-wrap card">
          <h2 class="form-title">Kirim Pesan</h2>
          <p class="form-desc">
            Isi formulir di bawah ini dan kami akan menghubungi Anda selambatnya
            dalam 1x24 jam kerja.
          </p>

          <form
            action={`https://formspree.io/f/${formspreeId}`}
            method="POST"
            class="contact-form"
          >
            <div class="form-group">
              <label for="name">Nama Lengkap</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Cth: Budi Santoso"
              />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="email">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="budi@example.com"
                />
              </div>
              <div class="form-group">
                <label for="phone">Nomor Telepon / WhatsApp</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  placeholder="0812-3456-7890"
                />
              </div>
            </div>

            <div class="form-group">
              <label for="category">Bidang Hukum Terkait</label>
              <select id="category" name="category" required>
                <option value="" disabled selected
                  >Pilih Kategori Masalah...</option
                >
                <option value="Hukum Pidana">Hukum Pidana</option>
                <option value="Hukum Perdata">Hukum Perdata</option>
                <option value="Hukum Korporasi">Hukum Korporasi</option>
                <option value="Hukum Keluarga">Hukum Keluarga</option>
                <option value="Lainnya">Lainnya / Tidak Tahu</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Pesan / Detail Singkat Masalah</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Jelaskan secara singkat masalah yang sedang Anda hadapi..."
              ></textarea>
            </div>

            <div class="form-submit">
              <Button type="submit" variant="primary" size="lg"
                >Kirim Pesan Sekarang</Button
              >
            </div>
          </form>
        </div>

        <!-- Right: Info & Maps -->
        <div class="contact-info-wrap">
          <div class="info-blocks">
            <div class="info-block card">
              <div class="info-icon" aria-hidden="true">
                <svg
                  width="24"
                  height="24"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                  ></path>
                </svg>
              </div>
              <div class="info-text">
                <h3>Kunjungi Kantor Kami</h3>
                <p>
                  Perum Pabuaran Asri Blok B10 No.09 Rt.13 Rw.08<br />Kec.
                  Cibinong, Kab. Bogor<br />Jawa Barat
                </p>
              </div>
            </div>

            <div class="info-block card">
              <div class="info-icon" aria-hidden="true">
                <svg
                  width="24"
                  height="24"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                  ></path>
                </svg>
              </div>
              <div class="info-text">
                <h3>Hubungi Langsung</h3>
                <p>
                  WhatsApp: <a
                    href="https://wa.me/6289516671039?text=Halo%20Sterling%20Legal%2C%20saya%20ingin%20berkonsultasi%20mengenai%20masalah%20hukum%20saya."
                    target="_blank"
                    rel="noopener noreferrer"
                    class="contact-link">+62 895-1667-1039</a
                  ><br />
                  Email: <a
                    href="mailto:syauqymubarok21@gmail.com"
                    class="contact-link">syauqymubarok21@gmail.com</a
                  >
                </p>
              </div>
            </div>
          </div>

          <div class="map-wrap card">
            <iframe
              src="https://www.google.com/maps?q=Perum+Pabuaran+Asri+Blok+B10+No.09+RT.13+RW.08+Cibinong+Bogor+Jawa+Barat&output=embed"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Lokasi Kantor Sterling Legal"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-hero {
    padding-top: calc(var(--header-height) + var(--space-3xl));
    padding-bottom: var(--space-xl);
    position: relative;
    overflow: hidden;
  }

  .blob-hero {
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(
      circle,
      rgba(215, 38, 61, 0.08) 0%,
      transparent 70%
    );
    top: -50px;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
    filter: blur(80px);
  }

  .page-hero-inner {
    max-width: 700px;
    margin-inline: auto;
  }

  .page-hero-sub {
    font-size: 1.15rem;
  }

  /* Contact Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--space-lg);
  }

  /* Form Styles */
  .contact-form-wrap {
    padding: var(--space-xl);
  }

  .form-title {
    font-size: 1.6rem;
    margin-bottom: 0.5rem;
  }

  .form-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: var(--space-lg);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    padding: 0.8rem 1rem;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-subtle);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(215, 38, 61, 0.15);
  }

  .form-submit {
    margin-top: var(--space-sm);
  }

  /* Info & Maps */
  .contact-info-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .info-blocks {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .info-block {
    padding: var(--space-lg);
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .info-icon {
    width: 48px;
    height: 48px;
    background: var(--color-gradient-soft);
    border: 1px solid rgba(215, 38, 61, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary-light);
    flex-shrink: 0;
  }

  .info-text h3 {
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
  }

  .info-text p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .contact-link {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .contact-link:hover {
    color: var(--color-primary-light);
  }

  .map-wrap {
    padding: 0;
    overflow: hidden;
    height: 100%;
    min-height: 300px;
  }

  .map-wrap iframe {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
