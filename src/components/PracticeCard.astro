---
interface Props {
  icon: string;   // SVG string
  title: string;
  description: string;
  badgeColor?: string;
}

const { icon, title, description } = Astro.props;
---

<div class="practice-card">
  <div class="practice-icon-wrap" aria-hidden="true">
    <Fragment set:html={icon} />
  </div>
  <div class="practice-content">
    <h3 class="practice-title">{title}</h3>
    <p class="practice-desc">{description}</p>
  </div>
  <div class="practice-arrow" aria-hidden="true">
    <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
    </svg>
  </div>
</div>

<style>
.practice-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-card);
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  cursor: default;
  position: relative;
  overflow: hidden;
  transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
}

.practice-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--color-gradient-soft);
  opacity: 0;
  transition: opacity var(--transition-slow);
  pointer-events: none;
  border-radius: inherit;
}

.practice-card:hover {
  border-color: var(--color-border);
  box-shadow: var(--glow-sm), var(--shadow-card);
  transform: translateY(-5px);
}

.practice-card:hover::after {
  opacity: 1;
}

.practice-icon-wrap {
  width: 56px;
  height: 56px;
  background: var(--color-gradient-soft);
  border: 1px solid rgba(215, 38, 61, 0.2);
  border-radius: var(--radius-card);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary-light);
  flex-shrink: 0;
  transition: box-shadow var(--transition-base);
  position: relative;
  z-index: 1;
}

.practice-card:hover .practice-icon-wrap {
  box-shadow: var(--glow-sm);
}

.practice-content {
  flex: 1;
  position: relative;
  z-index: 1;
}

.practice-title {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 0.6rem;
}

.practice-desc {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  line-height: 1.7;
}

.practice-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid var(--color-border-subtle);
  color: var(--color-text-muted);
  align-self: flex-end;
  transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast), transform var(--transition-fast);
  position: relative;
  z-index: 1;
}

.practice-card:hover .practice-arrow {
  color: var(--color-primary-light);
  border-color: var(--color-border);
  background: rgba(215, 38, 61, 0.1);
  transform: translateX(4px);
}
</style>
