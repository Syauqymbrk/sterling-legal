---
const navLinks = [
  { href: "/", label: "Beranda" },
  { href: "/about", label: "Tentang" },
  { href: "/practice-areas", label: "Bidang Hukum" },
  { href: "/team", label: "Tim" },
  { href: "/contact", label: "Kontak" },
];
---

<footer class="site-footer">
  <!-- Top decorative divider (Optional to match Aurelius) -->
  <div class="footer-divider-top" role="separator"></div>

  <div class="container">
    <!-- Top Centered Brand Area -->
    <div class="site-footer__top">
      <div class="site-footer__logo-wrap">
        <img
          src="/logo.svg"
          alt="Sterling Legal"
          width="56"
          height="56"
          class="site-footer__logo-img"
        />
      </div>
      <p class="site-footer__institution-text">Sterling Legal — Keadilan yang Berkualitas, Solusi yang Terpercaya</p>
    </div>

    <!-- 3 Column Grid Area -->
    <div class="site-footer__grid">
      <!-- Col 1: Brand Info -->
      <div>
        <h3 class="site-footer__brand">Sterling Legal</h3>
        <p class="site-footer__desc">
          Firma hukum profesional yang berdedikasi tinggi pada standar keunggulan, integritas, dan perlindungan hak-hak hukum klien di berbagai sektor hukum.
        </p>
        <p class="site-footer__meta">Terdaftar PERADI — Kantor Cibinong, Bogor</p>
      </div>

      <!-- Col 2: Navigation -->
      <div class="site-footer__nav-col">
        <h4 class="site-footer__heading">Navigasi</h4>
        <ul class="site-footer__links">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
          <li>
            <a href="https://wa.me/6289516671039?text=Halo%20Sterling%20Legal,%20saya%20membutuhkan%20bantuan%20hukum%20segera." class="emergency" aria-label="Hubungi layanan darurat">Darurat 24/7</a>
          </li>
        </ul>
      </div>

      <!-- Col 3: Address & Contact -->
      <div>
        <h4 class="site-footer__heading">Kantor Pusat</h4>
        <p class="site-footer__desc">
          Perum Pabuaran Asri Blok B10 No.09<br />
          Rt.13 Rw.08, Kec. Cibinong<br />
          Kab. Bogor, Jawa Barat
        </p>
        <div class="site-footer__contact">
          <div>
            <strong>Hotline:</strong> <a href="tel:+6289516671039" class="contact-link">+62 895-1667-1039</a>
          </div>
          <div>
            <strong>WhatsApp:</strong> <a href="https://wa.me/6289516671039?text=Halo%20Sterling%20Legal" target="_blank" rel="noopener" class="contact-link">Hubungi Kami</a>
          </div>
          <div>
            <strong>Email:</strong> <a href="mailto:syauqymubarok21@gmail.com" class="contact-link">syauqymubarok21@gmail.com</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom section -->
  <div class="footer-divider-bottom" role="separator"></div>
  <div class="container">
    <div class="site-footer__bottom">
      <div>&copy; 2026 Sterling Legal. Seluruh hak cipta dilindungi.</div>
      <div class="site-footer__bottom-tagline">Solusi Hukum Terpercaya — Keadilan Utama</div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface);
    margin-top: auto;
    position: relative;
    padding-bottom: var(--space-md);
  }

  .footer-divider-top,
  .footer-divider-bottom {
    height: 1px;
    background: var(--color-gradient);
    opacity: 0.5;
  }

  .site-footer__top {
    text-align: center;
    padding: var(--space-xl) 0 var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .site-footer__logo-wrap {
    width: 64px;
    height: 64px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--color-primary);
    box-shadow: var(--glow-sm);
  }

  .site-footer__logo-img {
    width: 44px;
    height: 44px;
  }

  .site-footer__institution-text {
    font-size: 1.1rem;
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.02em;
    margin: 0;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-2xl);
  }

  .site-footer__brand {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .site-footer__desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .site-footer__meta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary-light);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .site-footer__heading {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    position: relative;
    display: inline-block;
  }

  .site-footer__heading::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 20px;
    height: 2px;
    background: var(--color-primary);
  }

  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-link {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-text);
  }

  .emergency {
    font-size: 0.95rem;
    color: var(--color-primary-light);
    font-weight: 700;
    transition: color var(--transition-fast);
  }

  .emergency:hover {
    color: var(--color-text);
  }

  .site-footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: var(--space-sm);
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .site-footer__contact strong {
    color: var(--color-text);
    display: inline-block;
    min-width: 80px;
  }

  .contact-link {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .contact-link:hover {
    color: var(--color-primary-light);
  }

  .footer-divider-bottom {
    margin-top: 0;
    margin-bottom: var(--space-lg);
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-text-subtle);
  }

  .site-footer__bottom-tagline {
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
    
    .site-footer__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
