---
import MainLayout from '../layouts/MainLayout.astro';
import TeamCard from '../components/TeamCard.astro';
import Button from '../components/Button.astro';

const teamMembers = [
  { name: 'M. Syauqy Mubarok', credential: 'S.H.', specialization: 'Hukum Pidana & Perdata', initials: 'SM' },
  { name: 'Syahira Meyla', credential: 'S.H.', specialization: 'Hukum Keluarga', initials: 'SY' },
  { name: 'Zhafir Alfakhry', credential: 'S.H.', specialization: 'Hukum Korporasi', initials: 'ZA' },
  { name: 'Citra Fuja Fusfita', credential: 'S.H.', specialization: 'Hukum Perburuhan', initials: 'CF' },
  { name: 'Faqih Sya\'bana', credential: 'S.H.', specialization: 'Hukum Pidana', initials: 'FS' },
  { name: 'Gustapa Al Farizi', credential: 'S.H.', specialization: 'Hukum Perdata', initials: 'GA' },
  { name: 'Reza Purnama', credential: 'S.H.', specialization: 'Hukum Korporasi & Kontrak', initials: 'RP' }
];
---

<MainLayout
  title="Tim Kami — Pengacara Sterling Legal"
  description="Kenali tim pengacara profesional Sterling Legal yang berdedikasi tinggi dan berpengalaman dalam berbagai bidang hukum."
>
  <!-- Page Hero -->
  <section class="page-hero section" id="team-hero" aria-label="Tim Kami">
    <div class="blob blob-hero" aria-hidden="true"></div>
    <div class="container">
      <div class="page-hero-inner text-center">
        <div class="section-label" style="margin-inline:auto;display:flex;width:fit-content;">Pengacara Ahli</div>
        <h1>Kenali <span class="gradient-text">Tim Kami</span></h1>
        <div class="divider divider--center"></div>
        <p class="page-hero-sub">
          Di balik setiap kemenangan, terdapat tim yang tangguh, berdedikasi, dan tidak pernah menyerah. Kami adalah ahli strategi hukum Anda.
        </p>
      </div>
    </div>
  </section>

  <!-- Team Grid -->
  <section class="section section--sm" id="team-list" aria-label="Daftar Pengacara">
    <div class="container">
      <div class="team-grid">
        {teamMembers.map(member => (
          <TeamCard 
            name={member.name} 
            credential={member.credential} 
            specialization={member.specialization} 
            initials={member.initials} 
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" id="team-cta" aria-label="Konsultasi">
    <div class="container text-center">
      <div class="cta-banner">
        <h2>Butuh Pendampingan Hukum?</h2>
        <p>Tim pengacara kami siap memberikan konsultasi awal untuk memahami masalah Anda dan merancang langkah strategis yang tepat.</p>
        <div style="margin-top: var(--space-lg);">
          <Button href="/contact" variant="primary" size="lg">Jadwalkan Konsultasi</Button>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
.page-hero {
  padding-top: calc(var(--header-height) + var(--space-3xl));
  padding-bottom: var(--space-xl);
  position: relative;
  overflow: hidden;
}

.blob-hero {
  position: absolute;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(215,38,61,0.08) 0%, transparent 70%);
  top: -50px; left: 50%;
  transform: translateX(-50%);
  pointer-events: none;
  filter: blur(80px);
}

.page-hero-inner {
  max-width: 700px;
  margin-inline: auto;
}

.page-hero-sub {
  font-size: 1.15rem;
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-lg);
}

.cta-banner {
  background: var(--color-surface);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-lg);
  padding: var(--space-2xl) var(--space-xl);
  max-width: 800px;
  margin-inline: auto;
  position: relative;
  overflow: hidden;
}

.cta-banner::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--color-gradient);
}

.cta-banner h2 {
  font-size: 1.8rem;
  margin-bottom: var(--space-sm);
}

.cta-banner p {
  color: var(--color-text-muted);
}

@media (max-width: 1024px) {
  .team-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 768px) {
  .team-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .team-grid {
    grid-template-columns: 1fr;
  }
}
</style>
