---
import MainLayout from '../layouts/MainLayout.astro';
import PracticeCard from '../components/PracticeCard.astro';
import Button from '../components/Button.astro';

const iconCriminal = `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`;
const iconCivil = `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.97Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 5.49Z" /></svg>`;
const iconCorporate = `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" /></svg>`;
const iconFamily = `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>`;

const practices = [
  {
    icon: iconCriminal,
    title: 'Hukum Pidana',
    description: 'Pendampingan hukum yang tangguh untuk menghadapi tuduhan pidana. Kami memastikan hak-hak Anda terlindungi di setiap tahap proses peradilan, dari investigasi hingga persidangan.',
  },
  {
    icon: iconCivil,
    title: 'Hukum Perdata',
    description: 'Penyelesaian berbagai sengketa perdata seperti wanprestasi, sengketa lahan, hutang piutang, dan masalah kebendaan lainnya dengan fokus pada perlindungan aset dan mediasi.',
  },
  {
    icon: iconCorporate,
    title: 'Hukum Korporasi',
    description: 'Layanan legalitas untuk bisnis Anda, mencakup pendirian perusahaan, penyusunan dan review kontrak, perlindungan kekayaan intelektual, serta sengketa ketenagakerjaan.',
  },
  {
    icon: iconFamily,
    title: 'Hukum Keluarga',
    description: 'Menangani isu sensitif keluarga dengan kebijaksanaan dan profesionalisme, termasuk perceraian, hak asuh anak, pembagian harta gono-gini, hingga urusan waris.',
  }
];
---

<MainLayout
  title="Bidang Hukum — Layanan Sterling Legal"
  description="Sterling Legal menyediakan layanan di bidang hukum pidana, perdata, korporasi, dan keluarga dengan pendekatan yang profesional dan berorientasi solusi."
>
  <!-- Page Hero -->
  <section class="page-hero section" id="practice-hero" aria-label="Bidang Hukum">
    <div class="blob blob-hero" aria-hidden="true"></div>
    <div class="container">
      <div class="page-hero-inner text-center">
        <div class="section-label" style="margin-inline:auto;display:flex;width:fit-content;">Layanan Kami</div>
        <h1>Bidang <span class="gradient-text">Hukum</span></h1>
        <div class="divider divider--center"></div>
        <p class="page-hero-sub">
          Layanan hukum yang komprehensif, disesuaikan dengan kebutuhan Anda.<br />Tim kami memiliki rekam jejak yang terbukti di berbagai area praktik hukum.
        </p>
      </div>
    </div>
  </section>

  <!-- Grid Layanan -->
  <section class="section section--sm" id="practice-list" aria-label="Daftar Bidang Hukum">
    <div class="container">
      <div class="grid-2">
        {practices.map(p => (
          <PracticeCard icon={p.icon} title={p.title} description={p.description} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" id="practice-cta" aria-label="Konsultasi">
    <div class="container text-center">
      <div class="cta-banner">
        <h2>Tidak yakin masalah Anda masuk kategori mana?</h2>
        <p>Konsultasikan dengan tim ahli kami untuk mendapatkan gambaran yang jelas mengenai hak dan langkah hukum Anda.</p>
        <div style="margin-top: var(--space-lg);">
          <Button href="/contact" variant="primary" size="lg">Hubungi Kami Sekarang</Button>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
.page-hero {
  padding-top: calc(var(--header-height) + var(--space-3xl));
  padding-bottom: var(--space-xl);
  position: relative;
  overflow: hidden;
}

.blob-hero {
  position: absolute;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(215,38,61,0.08) 0%, transparent 70%);
  top: -50px; left: 50%;
  transform: translateX(-50%);
  pointer-events: none;
  filter: blur(80px);
}

.page-hero-inner {
  max-width: 700px;
  margin-inline: auto;
}

.page-hero-sub {
  font-size: 1.15rem;
}

.cta-banner {
  background: var(--color-surface);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-lg);
  padding: var(--space-2xl) var(--space-xl);
  max-width: 800px;
  margin-inline: auto;
  position: relative;
  overflow: hidden;
}

.cta-banner::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--color-gradient);
}

.cta-banner h2 {
  font-size: 1.8rem;
  margin-bottom: var(--space-sm);
}

.cta-banner p {
  color: var(--color-text-muted);
}
</style>
