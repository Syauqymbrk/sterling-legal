---
import MainLayout from '../layouts/MainLayout.astro';
import Button from '../components/Button.astro';
import CoreValueCard from '../components/CoreValueCard.astro';

const iconExcellence = `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/></svg>`;
const iconIntegrity = `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>`;
const iconDedication = `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>`;

const values = [
  { icon: iconExcellence, title: 'Keunggulan', description: 'Standar hukum tertinggi dalam setiap strategi dan solusi yang kami hadirkan.' },
  { icon: iconIntegrity, title: 'Integritas', description: 'Kejujuran, transparansi, dan etika profesi yang tidak pernah kami kompromikan.' },
  { icon: iconDedication, title: 'Dedikasi', description: 'Kehadiran penuh untuk setiap klien, dari konsultasi awal hingga penyelesaian akhir.' },
];

const timeline = [
  { year: '2014', event: 'Pendirian Sterling Legal', desc: 'Didirikan oleh M. Syauqy Mubarok, S.H. dengan visi menghadirkan layanan hukum yang berintegritas tinggi di wilayah Bogor.' },
  { year: '2016', event: 'Ekspansi Tim & Layanan', desc: 'Bergabungnya 3 pengacara baru dan perluasan layanan ke bidang hukum korporasi dan ketenagakerjaan.' },
  { year: '2019', event: 'Penghargaan & Pengakuan', desc: 'Sterling Legal diakui sebagai salah satu firma hukum terpercaya di Kabupaten Bogor dalam bidang mediasi perdata.' },
  { year: '2022', event: '100+ Klien Terlayani', desc: 'Mencapai tonggak 100 klien yang berhasil didampingi, dengan tingkat kepuasan yang sangat tinggi.' },
  { year: '2026', event: 'Sterling Legal Hari Ini', desc: 'Kini dengan 7 pengacara bersertifikat, melayani 200+ klien dan terus tumbuh dengan dedikasi yang sama sejak hari pertama.' },
];
---

<MainLayout
  title="Tentang Sterling Legal — Sejarah, Visi, dan Misi"
  description="Pelajari sejarah, visi, misi, dan nilai-nilai yang mendasari Sterling Legal dalam memberikan layanan hukum profesional di Bogor sejak 2014."
>
  <!-- Page Hero -->
  <section class="page-hero section" id="about-hero" aria-label="Tentang Sterling Legal">
    <div class="blob blob-hero" aria-hidden="true"></div>
    <div class="container">
      <div class="page-hero-inner">
        <div class="section-label">Tentang Kami</div>
        <h1>Mengenal <span class="gradient-text">Sterling Legal</span></h1>
        <div class="divider"></div>
        <p class="page-hero-sub">
          Firma hukum yang berdiri di atas prinsip keunggulan, integritas, dan dedikasi — melayani dengan penuh komitmen sejak 2014.
        </p>
      </div>
    </div>
  </section>

  <!-- Narasi Firm -->
  <section class="section section--sm" id="narasi" aria-label="Narasi firma">
    <div class="container">
      <div class="narasi-grid">
        <div class="narasi-text">
          <div class="section-label">Siapa Kami</div>
          <h2>Lebih dari Sekadar <span class="gradient-text">Firma Hukum</span></h2>
          <div class="divider"></div>
          <p>
            <strong>Sterling Legal</strong> berdiri di atas prinsip keunggulan, integritas, dan dedikasi. Kami menghadirkan layanan hukum profesional yang memadukan <strong>kompetensi mendalam</strong> dengan <strong>pendekatan personal</strong>, guna memastikan setiap klien memperoleh pendampingan hukum yang solid, terpercaya, dan berorientasi pada solusi nyata.
          </p>
          <p style="margin-top: var(--space-md);">
            Kami percaya bahwa hukum bukan sekadar aturan — hukum adalah <strong>alat keadilan</strong>. Setiap klien yang datang kepada kami membawa cerita, harapan, dan tantangan yang unik. Itulah mengapa kami tidak menerapkan pendekatan satu ukuran untuk semua. Kami mendengarkan, memahami, dan merancang strategi yang benar-benar tepat untuk situasi Anda.
          </p>
          <div style="margin-top: var(--space-lg);">
            <Button href="/contact" variant="primary" size="md">
              Hubungi Kami
            </Button>
          </div>
        </div>
        <div class="narasi-visual" aria-hidden="true">
          <div class="visual-card-stack">
            <div class="stack-card stack-card-1">
              <div class="stack-icon">⚖️</div>
              <p class="stack-text">Kompetensi Mendalam</p>
            </div>
            <div class="stack-card stack-card-2">
              <div class="stack-icon">🤝</div>
              <p class="stack-text">Pendekatan Personal</p>
            </div>
            <div class="stack-card stack-card-3">
              <div class="stack-icon">🏆</div>
              <p class="stack-text">Orientasi Solusi Nyata</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Visi & Misi -->
  <section class="section visi-misi-section" id="visi-misi" aria-label="Visi dan misi">
    <div class="container">
      <div class="section-header text-center">
        <div class="section-label" style="margin-inline:auto;display:flex;width:fit-content;">Visi & Misi</div>
        <h2>Arah dan <span class="gradient-text">Tujuan Kami</span></h2>
        <div class="divider divider--center"></div>
      </div>
      <div class="visi-misi-grid">
        <div class="vm-card">
          <div class="vm-icon" aria-hidden="true">
            <svg width="30" height="30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
          </div>
          <h3>Visi</h3>
          <p>Menjadi firma hukum terdepan yang dikenal atas integritas tak tergoyahkan, keunggulan dalam praktik hukum, dan kontribusi nyata terhadap tegaknya keadilan di masyarakat.</p>
        </div>
        <div class="vm-card">
          <div class="vm-icon" aria-hidden="true">
            <svg width="30" height="30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
          </div>
          <h3>Misi</h3>
          <ul class="mission-list">
            <li>Memberikan layanan hukum yang profesional, etis, dan berorientasi pada kepentingan terbaik klien.</li>
            <li>Menghadirkan akses keadilan yang merata melalui pendampingan hukum yang personal dan terpercaya.</li>
            <li>Terus mengembangkan kompetensi tim dalam menghadapi dinamika hukum yang terus berkembang.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="section section--sm" id="values" aria-label="Nilai-nilai inti">
    <div class="container">
      <div class="section-header text-center">
        <div class="section-label" style="margin-inline:auto;display:flex;width:fit-content;">Nilai Inti</div>
        <h2>Tiga Pilar <span class="gradient-text">Sterling Legal</span></h2>
        <div class="divider divider--center"></div>
      </div>
      <div class="grid-3">
        {values.map(v => (
          <CoreValueCard icon={v.icon} title={v.title} description={v.description} />
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section section--sm" id="timeline" aria-label="Timeline sejarah">
    <div class="container">
      <div class="section-header text-center">
        <div class="section-label" style="margin-inline:auto;display:flex;width:fit-content;">Perjalanan Kami</div>
        <h2>Sejarah <span class="gradient-text">Sterling Legal</span></h2>
        <div class="divider divider--center"></div>
      </div>
      <div class="timeline">
        {timeline.map((item, i) => (
          <div class={`timeline-item ${i % 2 === 0 ? 'timeline-item--left' : 'timeline-item--right'}`}>
            <div class="timeline-card card">
              <span class="timeline-year gradient-text">{item.year}</span>
              <h3 class="timeline-event">{item.event}</h3>
              <p class="timeline-desc">{item.desc}</p>
            </div>
            <div class="timeline-dot" aria-hidden="true"></div>
          </div>
        ))}
        <div class="timeline-line" aria-hidden="true"></div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
/* Page Hero */
.page-hero {
  padding-top: calc(var(--header-height) + var(--space-3xl));
  padding-bottom: var(--space-2xl);
  position: relative;
  overflow: hidden;
  text-align: center;
}

.blob-hero {
  position: absolute;
  width: 600px; height: 400px;
  background: radial-gradient(ellipse, rgba(215,38,61,0.1) 0%, transparent 70%);
  top: 0; left: 50%;
  transform: translateX(-50%);
  filter: blur(60px);
  pointer-events: none;
}

.page-hero-inner {
  max-width: 700px;
  margin-inline: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-sm);
}

.page-hero-sub {
  font-size: 1.15rem;
  text-align: center;
  max-width: 560px;
}

/* Narasi */
.narasi-grid {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: var(--space-xl);
  align-items: center;
}

.narasi-text {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.narasi-text p { font-size: 1rem; }

/* Card stack visual */
.visual-card-stack {
  position: relative;
  height: 320px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stack-card {
  position: absolute;
  background: var(--color-surface);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-card);
  padding: var(--space-md);
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  width: 220px;
  box-shadow: var(--shadow-card);
  transition: transform var(--transition-slow);
}

.stack-card:hover { transform: scale(1.04); }

.stack-card-1 { top: 0; left: 0; transform: rotate(-4deg); }
.stack-card-2 { top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 2; box-shadow: var(--glow-sm), var(--shadow-card); border-color: var(--color-border); }
.stack-card-3 { bottom: 0; right: 0; transform: rotate(4deg); }

.stack-icon { font-size: 1.8rem; }
.stack-text { font-size: 0.88rem; font-weight: 600; color: var(--color-text); }

/* Visi Misi */
.visi-misi-section {
  background: linear-gradient(to bottom, transparent, rgba(215,38,61,0.03), transparent);
}

.visi-misi-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-lg);
}

.vm-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-card);
  padding: var(--space-xl);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  transition: border-color var(--transition-base), box-shadow var(--transition-base);
}

.vm-card:hover {
  border-color: var(--color-border);
  box-shadow: var(--glow-sm);
}

.vm-icon {
  width: 56px; height: 56px;
  background: var(--color-gradient-soft);
  border: 1px solid rgba(215, 38, 61, 0.2);
  border-radius: var(--radius-card);
  display: flex; align-items: center; justify-content: center;
  color: var(--color-primary-light);
}

.vm-card h3 { font-size: 1.4rem; }
.vm-card p { font-size: 0.95rem; color: var(--color-text-muted); }

.mission-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.mission-list li {
  font-size: 0.92rem;
  color: var(--color-text-muted);
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
}

.mission-list li::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
  margin-top: 0.55rem;
}

/* Timeline */
.timeline {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
  padding: var(--space-md) 0;
}

.timeline-line {
  position: absolute;
  left: 50%;
  top: 0; bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, transparent, var(--color-primary), transparent);
  transform: translateX(-50%);
}

.timeline-item {
  display: flex;
  justify-content: flex-end;
  padding-right: calc(50% + var(--space-lg));
  position: relative;
}

.timeline-item--right {
  justify-content: flex-start;
  padding-right: 0;
  padding-left: calc(50% + var(--space-lg));
}

.timeline-card {
  max-width: 360px;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.timeline-year {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  font-weight: 800;
}

.timeline-event {
  font-size: 1rem;
  font-weight: 700;
}

.timeline-desc {
  font-size: 0.88rem;
  color: var(--color-text-muted);
  margin: 0;
}

.timeline-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 12px; height: 12px;
  background: var(--color-primary);
  border-radius: 50%;
  box-shadow: var(--glow-sm);
  border: 2px solid var(--color-bg);
}

/* Responsive */
@media (max-width: 900px) {
  .narasi-grid { grid-template-columns: 1fr; }
  .visual-card-stack { display: none; }
  .visi-misi-grid { grid-template-columns: 1fr; }
  .timeline-line { left: 16px; }
  .timeline-item, .timeline-item--right {
    padding: 0 0 0 calc(16px + var(--space-md) + 12px);
    justify-content: flex-start;
  }
  .timeline-dot { left: 16px; }
  .timeline-card { max-width: 100%; }
}
</style>
